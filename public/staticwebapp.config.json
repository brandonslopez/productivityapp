{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/auth-complete.html",
      "/assets/*",
      "/*.{png,jpg,gif,css,js,ico,svg,woff,woff2}"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
